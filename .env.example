# Copy this file to .env and fill in values. Never commit .env.

# Backend
DATABASE_URL=postgresql://donsend:password@db:5432/donsend
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REGISTRATION_OPEN=false

# Cookie security — set to false in local dev (HTTP), true in production (HTTPS)
SECURE_COOKIES=true

# Postgres (used by Docker Compose)
POSTGRES_USER=donsend
POSTGRES_PASSWORD=password
POSTGRES_DB=donsend
